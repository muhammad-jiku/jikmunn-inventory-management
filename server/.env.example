# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/inventory_management

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-at-least-16-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-at-least-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP / Email (optional — uses Ethereal fake SMTP if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inventory Alerts" <alerts@inventory.local>

# Sentry (optional — leave empty to disable error tracking)
SENTRY_DSN=

# Low Stock Alert Recipient (fallback when no email in request body)
ALERT_EMAIL=
